# Copy to `config/.env` and fill in the real values.

# Security / environment
SECRET_KEY_VALUE=change-me
DEBUG_VALUE=true
ALLOWED_HOSTS_VALUE=127.0.0.1

# Email (SMTP)
SENDER_EMAIL_VALUE=your_email@example.com
EMAIL_PORT=465
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_app_password

# OAuth (Social Login) - Google
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your_google_client_id
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your_google_client_secret

# OAuth (Social Login) - GitHub
SOCIAL_AUTH_GITHUB_KEY=your_github_client_id
SOCIAL_AUTH_GITHUB_SECRET=your_github_client_secret

